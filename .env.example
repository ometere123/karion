# === Database ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/karion?schema=public"

# === GenLayer StudioNet ===
GENLAYER_RPC_URL="https://studio.genlayer.com/api"
GENLAYER_CHAIN_ID="61999"
GENLAYER_EXPLORER_URL="https://explorer-studio.genlayer.com"
GENLAYER_CONTRACT_ADDRESS=""

# === UploadThing ===
UPLOADTHING_TOKEN=""

# === Admin ===
ADMIN_EMAIL=""

# === Security ===
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SIGNING_SECRET=""
# SYSTEM_RECOVERY_SECRET encrypts each user's WEK at signup so password reset
# can automatically re-wrap the wallet without requiring the user's recovery key.
# NEVER commit this value. Rotation requires re-wrapping all SYSTEM wraps.
SYSTEM_RECOVERY_SECRET=""

# === App ===
FRONTEND_URL="http://localhost:3000"
API_PORT="4000"
NODE_ENV="development"

# === Email (SMTP) ===
# Leave blank in development — reset links print to the API console instead
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@karion.app"
