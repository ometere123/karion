# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/karion?schema=public"

# GenLayer StudioNet
GENLAYER_RPC_URL="https://studio.genlayer.com/api"
GENLAYER_CHAIN_ID="61999"
GENLAYER_EXPLORER_URL="https://explorer-studio.genlayer.com"
GENLAYER_CONTRACT_ADDRESS=""
# SECURITY: never log or commit this value
GENLAYER_DEPLOYER_PRIVATE_KEY=""

# Session signing — required at startup.
# SECURITY: never log this value.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SIGNING_SECRET=""

# Market sync worker — set to "true" to enable the background indexer.
# Leave false (default) to avoid auto-resolving markets during tests or scripts.
ENABLE_MARKET_SYNC="false"
# How often the sync worker runs (ms). Default: 60000
SYNC_INTERVAL_MS="60000"
# Minimum stake in wei (optional). Unset = no minimum.
MIN_STAKE_WEI=""

# UploadThing
UPLOADTHING_TOKEN=""

# Admin — the email address that has ADMIN role capabilities via /auth routes
ADMIN_EMAIL=""

# App
FRONTEND_URL="http://localhost:3000"
API_PORT="4000"
NODE_ENV="development"

# Email (SMTP) — leave SMTP_HOST blank to print reset links to console in dev
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Karion <no-reply@example.com>"
